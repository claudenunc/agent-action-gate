# Agent Action Gate — example environment
#
# Copy to .env and fill in values for the skill executors you want enabled.
# Skills with missing credentials are simply unavailable; the gate still works.

# Auto-execute low-risk actions without queueing for human approval.
# Default: false. Only set true if you have audited the registry.
ACTION_GATE_AUTO_APPROVE_LOW=false

# IFTTT webhook (skill: ifttt_notify)
IFTTT_WEBHOOK_KEY=
IFTTT_EVENT_NAME=agent_alert

# SMTP for outbound email (skills: email_notify, sms_email_notify)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# SMS via carrier email gateway (skill: sms_email_notify)
SMS_EMAIL_TO=
